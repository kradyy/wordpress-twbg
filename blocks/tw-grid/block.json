{
    "apiVersion": 2,
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "name": "twgb/tw-grid",
    "version": "1.0.0",
    "title": "TW Grid",
    "category": "twgb",
    "icon": "grid-view",
    "description": "CSS Grid layout block with Tailwind classes.",
    "keywords": [
        "grid",
        "columns",
        "layout",
        "tailwind"
    ],
    "textdomain": "tw-gutenberg-bridge",
    "supports": {
        "html": false,
        "anchor": true,
        "align": [ "full", "wide" ]
    },
    "attributes": {
        "twClasses": {
            "type": "string",
            "default": "grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4"
        },
        "responsiveAttrs": {
            "type": "object",
            "default": {}
        },
        "rawMode": {
            "type": "boolean",
            "default": false
        }
    },
    "render": "file:./render.php"
}