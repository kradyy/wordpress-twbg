{
    "apiVersion": 2,
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "name": "twgb/tw-container",
    "version": "1.0.0",
    "title": "TW Container",
    "category": "twgb",
    "icon": "layout",
    "description": "A lightweight container block with Tailwind utility classes.",
    "keywords": [
        "container",
        "wrapper",
        "tailwind",
        "layout"
    ],
    "textdomain": "tw-gutenberg-bridge",
    "supports": {
        "html": false,
        "anchor": true,
        "align": [ "full", "wide" ]
    },
    "attributes": {
        "twClasses": {
            "type": "string",
            "default": ""
        },
        "responsiveAttrs": {
            "type": "object",
            "default": {}
        },
        "tag": {
            "type": "string",
            "default": "div",
            "enum": [
                "div",
                "section",
                "article",
                "main",
                "aside",
                "header",
                "footer",
                "nav"
            ]
        },
        "rawMode": {
            "type": "boolean",
            "default": false
        }
    },
    "render": "file:./render.php"
}