{
    "apiVersion": 2,
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "name": "twgb/tw-image",
    "version": "1.0.0",
    "title": "TW Image",
    "category": "twgb",
    "icon": "format-image",
    "description": "Image block with Tailwind utility classes.",
    "keywords": [
        "image",
        "photo",
        "tailwind"
    ],
    "textdomain": "tw-gutenberg-bridge",
    "supports": {
        "html": false,
        "anchor": true
    },
    "attributes": {
        "src": {
            "type": "string",
            "default": ""
        },
        "alt": {
            "type": "string",
            "default": ""
        },
        "twClasses": {
            "type": "string",
            "default": ""
        },
        "responsiveAttrs": {
            "type": "object",
            "default": {}
        },
        "rawMode": {
            "type": "boolean",
            "default": false
        }
    },
    "render": "file:./render.php"
}