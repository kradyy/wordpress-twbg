{
    "apiVersion": 2,
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "name": "twgb/tw-flex",
    "version": "1.0.0",
    "title": "TW Flex",
    "category": "twgb",
    "icon": "columns",
    "description": "Flexbox layout block with Tailwind classes.",
    "keywords": [
        "flex",
        "row",
        "column",
        "layout",
        "tailwind"
    ],
    "textdomain": "tw-gutenberg-bridge",
    "supports": {
        "html": false,
        "anchor": true,
        "align": [ "full", "wide" ]
    },
    "attributes": {
        "twClasses": {
            "type": "string",
            "default": "flex flex-col md:flex-row gap-4"
        },
        "responsiveAttrs": {
            "type": "object",
            "default": {}
        },
        "rawMode": {
            "type": "boolean",
            "default": false
        }
    },
    "render": "file:./render.php"
}