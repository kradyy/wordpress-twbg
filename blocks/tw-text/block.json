{
    "apiVersion": 2,
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "name": "twgb/tw-text",
    "version": "1.0.0",
    "title": "TW Text",
    "category": "twgb",
    "icon": "editor-textcolor",
    "description": "Text block with full Tailwind class support.",
    "keywords": [
        "text",
        "heading",
        "paragraph",
        "tailwind"
    ],
    "textdomain": "tw-gutenberg-bridge",
    "supports": {
        "html": false,
        "anchor": true
    },
    "attributes": {
        "content": {
            "type": "string",
            "default": ""
        },
        "twClasses": {
            "type": "string",
            "default": ""
        },
        "responsiveAttrs": {
            "type": "object",
            "default": {}
        },
        "tag": {
            "type": "string",
            "default": "p",
            "enum": [
                "p",
                "h1",
                "h2",
                "h3",
                "h4",
                "h5",
                "h6",
                "span",
                "blockquote"
            ]
        },
        "rawMode": {
            "type": "boolean",
            "default": false
        }
    },
    "render": "file:./render.php"
}